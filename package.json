{
  "name": "vite-boilerplate",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint . && stylelint \"**/*.{css,scss}\" --fix",
    "prepare": "husky install",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.8",
    "@storybook/addon-actions": "^7.0.5",
    "@storybook/addon-essentials": "^7.0.5",
    "@storybook/addon-interactions": "^6.5.16",
    "@storybook/addon-links": "^7.0.6",
    "@storybook/addon-toolbars": "^6.5.16",
    "@storybook/builder-vite": "^7.0.7",
    "@storybook/react": "^6.4.22",
    "@storybook/testing-library": "^0.1.0",
    "@types/react": "^18.0.32",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.57.0",
    "@vitejs/plugin-react": "^4.0.0",
    "babel-loader": "^9.1.2",
    "eslint": "^8.39.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-prefer-function-component": "^3.1.0",
    "eslint-plugin-storybook": "^0.6.11",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "prettier": "2.8.7",
    "storybook-addon-performance": "^0.17.1",
    "storybook-dark-mode": "^2.1.1",
    "stylelint": "^15.6.0",
    "stylelint-config-prettier": "^9.0.4",
    "stylelint-config-standard": "^32.0.0",
    "typescript": "^4.9.5",
    "vite": "^4.2.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint",
    "*.css": "stylelint",
    "*.scss": "stylelint --syntax=scss",
    "*.{js,jsx,ts,tsx,md,html}": "prettier --write"
  }
}
