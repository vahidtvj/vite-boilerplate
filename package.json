{
  "name": "vite-boilerplate",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint . && stylelint \"**/*.{css,scss}\" --fix",
    "prepare": "husky install",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.8",
    "@storybook/addon-actions": "^7.2.1",
    "@storybook/addon-essentials": "^7.0.27",
    "@storybook/addon-interactions": "^7.0.23",
    "@storybook/addon-links": "^7.1.0",
    "@storybook/addon-toolbars": "^7.0.24",
    "@storybook/builder-vite": "^7.1.1",
    "@storybook/react": "^7.0.27",
    "@storybook/testing-library": "^0.2.0",
    "@types/react": "^18.2.17",
    "@types/react-dom": "^18.2.4",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.0.4",
    "babel-loader": "^9.1.3",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.1",
    "eslint-plugin-react-prefer-function-component": "^3.1.0",
    "eslint-plugin-storybook": "^0.6.12",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "3.0.0",
    "storybook-addon-performance": "^0.17.1",
    "storybook-dark-mode": "^3.0.1",
    "stylelint": "^15.10.1",
    "stylelint-config-prettier": "^9.0.4",
    "stylelint-config-standard": "^34.0.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint",
    "*.css": "stylelint",
    "*.scss": "stylelint --syntax=scss",
    "*.{js,jsx,ts,tsx,md,html}": "prettier --write"
  }
}
